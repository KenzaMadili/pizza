<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1C0A0F"
    tools:context="">

    <!-- Header bordeaux profond -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="16dp"
        android:paddingTop="48dp"
        android:paddingBottom="20dp"
        android:background="#2E0D17">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pizza Recipes"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:textColor="#D4A843"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.02" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nos créations gourmandes"
                    android:textSize="12sp"
                    android:textColor="#8B5E6B"
                    android:fontFamily="sans-serif-light"
                    android:layout_marginTop="2dp"
                    android:letterSpacing="0.04" />

            </LinearLayout>

            <ImageView
                android:id="@+id/btnShare"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/share"
                android:layout_gravity="center_vertical"
                android:background="@drawable/ripple_circle_gold"
                android:padding="10dp" />

        </LinearLayout>

        <!-- Séparateur doré -->
        <View
            android:layout_width="40dp"
            android:layout_height="2dp"
            android:background="#D4A843"
            android:layout_marginTop="14dp" />

    </LinearLayout>

    <ListView
        android:id="@+id/liste"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="@null"
        android:dividerHeight="0dp"
        android:clipToPadding="false"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="14dp"
        android:paddingBottom="14dp"
        android:scrollbarStyle="outsideOverlay" />

</LinearLayout>
